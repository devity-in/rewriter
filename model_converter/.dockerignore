# Docker ignore file to reduce build context size

# Python
venv/
__pycache__/
*.py[cod]
*$py.class
*.so

# Temporary files
*.tflite
temp/
tmp/
*.task

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Documentation (not needed in container)
README.md
KNOWN_ISSUES.md
*.md

# Scripts (only need the main converter)
setup_env.sh
fix_library_issue.sh
check_python.sh
convert.sh

